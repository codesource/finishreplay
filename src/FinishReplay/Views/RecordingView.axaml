<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FinishReplay.ViewModels"
             xmlns:models="using:FinishReplay.Models"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="660"
             x:Class="FinishReplay.Views.RecordingView"
             x:DataType="vm:RecordingViewModel">

    <Grid ColumnDefinitions="*,380" Margin="16">

        <!-- Left: preview + transport -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">

            <!-- Transport controls -->
            <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="12"
                    Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="● Record" Command="{Binding StartRecordingCommand}"
                                Background="#DC2626" Foreground="White" Padding="16,8" />
                        <Button Content="■ Stop" Command="{Binding StopRecordingCommand}" Padding="16,8" />
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <!-- Manual timing triggers (also useful before a real device is connected) -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Manual triggers:" VerticalAlignment="Center" />
                        <Button Content="Start" Command="{Binding TriggerStartCommand}" />
                        <Button Content="Intermediate" Command="{Binding TriggerIntermediateCommand}" />
                        <Button Content="Stop" Command="{Binding TriggerStopCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Live preview placeholder -->
            <Border Background="#111827" CornerRadius="6" MinHeight="320">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="Live preview" Foreground="#9CA3AF"
                               FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="Camera output will appear here once the video backend is connected."
                               Foreground="#6B7280" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </DockPanel>

        <!-- Right: cameras, calibration, settings -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="16">

                <!-- Cameras -->
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Cameras" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="⟳ Discover" Command="{Binding DiscoverCamerasCommand}" />
                    </Grid>

                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                        <ItemsControl ItemsSource="{Binding Cameras}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CameraProfileRowViewModel">
                                    <Border Padding="8" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SourceType}" Foreground="#6B7280" FontSize="12" />
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="✕"
                                                        Command="{Binding $parent[ItemsControl].((vm:RecordingViewModel)DataContext).RemoveCameraCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Manual offset (ms)"
                                                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" />
                                                <NumericUpDown Grid.Row="0" Grid.Column="1" Increment="1"
                                                               Value="{Binding ManualOffsetMs}" FontSize="12" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                                           Text="{Binding CalibrationStatus}" Foreground="#2563EB" FontSize="12" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Add a network camera -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <ComboBox Grid.Column="0" Margin="0,0,6,0" Width="92"
                                  ItemsSource="{Binding AvailableSourceTypes}"
                                  SelectedItem="{Binding NewCameraType}" />
                        <TextBox Grid.Column="1" Margin="0,0,6,0" Watermark="rtsp:// or http:// URL"
                                 Text="{Binding NewCameraUrl}" />
                        <Button Grid.Column="2" Content="Add" Command="{Binding AddCameraCommand}" />
                    </Grid>
                </StackPanel>

                <!-- Latency calibration -->
                <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="6" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Latency calibration" FontWeight="SemiBold" />
                        <TextBlock Text="Flashes an LED trigger and measures each selected camera's latency, then computes relative sync offsets."
                                   Foreground="#6B7280" TextWrapping="Wrap" FontSize="12" />
                        <Button Content="Calibrate latency" Command="{Binding CalibrateLatencyCommand}"
                                IsEnabled="{Binding !IsCalibrating}" />
                        <TextBlock Text="{Binding CalibrationSummary}" Foreground="#374151"
                                   TextWrapping="Wrap" FontSize="12" />
                    </StackPanel>
                </Border>

                <StackPanel Spacing="6">
                    <TextBlock Text="Pre-record (seconds)" FontWeight="SemiBold" />
                    <NumericUpDown Value="{Binding PreRecordSeconds}" Minimum="0" Maximum="60" Increment="1" />
                    <TextBlock Text="Seconds kept in the rolling buffer before a start trigger."
                               Foreground="#6B7280" TextWrapping="Wrap" FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Post-record (seconds)" FontWeight="SemiBold" />
                    <NumericUpDown Value="{Binding PostRecordSeconds}" Minimum="0" Maximum="60" Increment="1" />
                    <TextBlock Text="Seconds recorded after a stop trigger."
                               Foreground="#6B7280" TextWrapping="Wrap" FontSize="12" />
                </StackPanel>

                <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                        CornerRadius="6" Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Timing device" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding TimingStatusText}" Foreground="#6B7280" />
                    </StackPanel>
                </Border>

                <!-- Triggers captured this session -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Triggers" FontWeight="SemiBold" />
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" MinHeight="100">
                        <ListBox ItemsSource="{Binding Markers}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:TimingTrigger">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Type}" FontWeight="SemiBold" Width="92" />
                                        <TextBlock Text="{Binding VideoTime, StringFormat='mm\\:ss\\.fff'}"
                                                   Foreground="#6B7280" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>

                <!-- Advanced / debug, collapsed by default -->
                <Expander Header="Advanced">
                    <StackPanel Spacing="6" Margin="0,8,0,0">
                        <TextBlock Text="Output folder" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SessionsDirectory}" Foreground="#6B7280"
                                   TextWrapping="Wrap" FontSize="12" />
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
