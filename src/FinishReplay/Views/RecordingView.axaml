<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FinishReplay.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="660"
             x:Class="FinishReplay.Views.RecordingView"
             x:DataType="vm:RecordingViewModel">

    <DockPanel Margin="16">

        <!-- Footer: record controls + event data -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="12"
                Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                <!-- left: record / stop / status (+ timing when a device is configured) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="● Record all" Command="{Binding StartRecordingCommand}"
                            Background="#DC2626" Foreground="White" Padding="16,8" />
                    <Button Content="■ Stop" Command="{Binding StopRecordingCommand}" Padding="16,8" />
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="6,0,0,0" />

                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                Margin="10,0,0,0" IsVisible="{Binding HasTimingDevice}">
                        <TextBlock Text="{Binding TimingStatusText}" Foreground="#6B7280" FontSize="12" VerticalAlignment="Center" />
                        <Button Content="Connect" Command="{Binding ConnectTimingCommand}" />
                        <Button Content="Disconnect" Command="{Binding DisconnectTimingCommand}" />
                    </StackPanel>
                </StackPanel>

                <!-- middle: required hint -->
                <TextBlock Grid.Column="1" Text="Category and discipline are required before recording."
                           Foreground="#DC2626" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding !HasEventContext}" />

                <!-- right: event -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Event" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="Category *" VerticalAlignment="Center" Foreground="#6B7280" FontSize="12" />
                    <TextBox Width="120" Text="{Binding Category}" Watermark="U18" />
                    <TextBlock Text="Discipline *" VerticalAlignment="Center" Foreground="#6B7280" FontSize="12" />
                    <TextBox Width="120" Text="{Binding Discipline}" Watermark="100m" />
                    <TextBlock Text="Series #" VerticalAlignment="Center" Foreground="#6B7280" FontSize="12" />
                    <NumericUpDown Width="110" Minimum="1" Increment="1" Value="{Binding SeriesNumber}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Cameras fill the remaining space in a grid -->
        <Border Background="#0B1220" CornerRadius="6" Padding="6">
            <Grid>
                <ItemsControl ItemsSource="{Binding Cameras}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CameraProfileRowViewModel">
                            <Border Margin="4" CornerRadius="6" ClipToBounds="True"
                                    Background="#111827" BorderBrush="#1F2937" BorderThickness="1">
                                <Border.ContextMenu>
                                    <ContextMenu x:CompileBindings="False">
                                        <MenuItem Header="Refresh camera" Command="{Binding RefreshCommand}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Image Source="{Binding Preview}" Stretch="Uniform" />

                                    <Border VerticalAlignment="Bottom" Background="#990B1220" Padding="8,4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding DisplayName}" Foreground="#E5E7EB" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SourceType}" Foreground="#9CA3AF" FontSize="12"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Resolution}" Foreground="#9CA3AF" FontSize="12"
                                                           IsVisible="{Binding Resolution, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                <TextBlock Text="{Binding FrameRate}" Foreground="#9CA3AF" FontSize="12"
                                                           IsVisible="{Binding FrameRate, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="waiting for frames…" Foreground="#6B7280" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="{Binding Preview, Converter={x:Static ObjectConverters.IsNull}}" />

                                    <Border Background="#111827" Padding="14" VerticalAlignment="Stretch"
                                            IsVisible="{Binding ErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding ErrorText}" Foreground="#F87171" FontSize="12"
                                                   TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No cameras configured — add them in Settings."
                           Foreground="#9CA3AF" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding !HasCameras}" />
            </Grid>
        </Border>
    </DockPanel>

</UserControl>
