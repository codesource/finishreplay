<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FinishReplay.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="660"
             x:Class="FinishReplay.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <DockPanel Margin="16">

        <!-- Save bar -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Save settings" Command="{Binding SaveCommand}"
                        Background="#2563EB" Foreground="White" Padding="16,8" />
                <TextBlock Text="{Binding StatusText}" Foreground="#16A34A" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <TabControl>

            <!-- Recording -->
            <TabItem Header="Recording">
                <ScrollViewer>
                    <StackPanel Spacing="16" Margin="4,12" MaxWidth="520" HorizontalAlignment="Left">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Pre-record (seconds)" FontWeight="SemiBold" />
                            <NumericUpDown Value="{Binding PreRecordSeconds}" Minimum="0" Maximum="60" Increment="1" />
                            <TextBlock Text="Rolling buffer kept before a start trigger."
                                       Foreground="#6B7280" FontSize="12" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Post-record (seconds)" FontWeight="SemiBold" />
                            <NumericUpDown Value="{Binding PostRecordSeconds}" Minimum="0" Maximum="60" Increment="1" />
                            <TextBlock Text="Recording continues this long after a stop trigger."
                                       Foreground="#6B7280" FontSize="12" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Recording mode" FontWeight="SemiBold" />
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding RecordingModes}"
                                      SelectedItem="{Binding RecordingMode}" />
                            <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12"
                                       Text="Transcode re-encodes every camera to MJPEG AVI. Passthrough copies RTSP/H.264 to MP4 at original quality (no re-encode); non-H.264 sources fall back to transcode." />
                        </StackPanel>
                        <TextBlock Text="Event context (category, discipline, series) is set on the Recording screen."
                                   Foreground="#6B7280" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Storage -->
            <TabItem Header="Storage">
                <StackPanel Spacing="10" Margin="4,12" MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock Text="Where recordings are stored" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding StorageDirectory}" />
                        <Button Grid.Column="1" Name="BrowseButton" Content="Browse…" Click="OnBrowseClick" />
                    </Grid>
                    <TextBlock Text="Each session writes one video file per camera plus a &lt;session&gt;.timing.json metadata file here."
                               Foreground="#6B7280" TextWrapping="Wrap" FontSize="12" />

                    <Separator />

                    <TextBlock Text="FFmpeg executable (for RTSP / USB / H.264 cameras)" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding FfmpegPath}"
                                 Watermark="ffmpeg (auto-detected) or full path to ffmpeg.exe" />
                        <Button Grid.Column="1" Margin="0,0,6,0" Content="Detect" Command="{Binding DetectFfmpegCommand}" />
                        <Button Grid.Column="2" Content="Browse…" Click="OnBrowseFfmpegClick" />
                    </Grid>
                    <TextBlock Text="{Binding FfmpegStatus}" TextWrapping="Wrap" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Don't have it?" Foreground="#6B7280" FontSize="12" VerticalAlignment="Center" />
                        <Button Content="Get FFmpeg" Command="{Binding OpenFfmpegDownloadCommand}" />
                    </StackPanel>
                    <TextBlock Text="Auto-detected from the app folder, PATH and common install locations (winget / chocolatey / scoop / Homebrew). A bundled copy can be placed in an 'ffmpeg' folder next to the app."
                               Foreground="#6B7280" TextWrapping="Wrap" FontSize="12" />

                    <Separator />

                    <TextBlock Text="Video backend (RTSP / USB)" FontWeight="SemiBold" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding VideoBackends}"
                              SelectedItem="{Binding VideoBackend}" />
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12"
                               Text="External process shells out to ffmpeg. Isolated worker embeds FFmpeg (libav) in a separate crash-safe process — a codec crash can't take down the app; falls back to the external process if the worker isn't bundled." />
                </StackPanel>
            </TabItem>

            <!-- Cameras -->
            <TabItem Header="Cameras">
                <DockPanel Margin="4,12" DataContext="{Binding CameraSettings}" x:DataType="vm:CameraSettingsViewModel">
                    <StackPanel DockPanel.Dock="Top" Spacing="8">
                        <TextBlock Text="Configured cameras" FontWeight="SemiBold" />

                        <!-- Add camera: type-aware form -->
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Add a camera" FontWeight="SemiBold" FontSize="13" />
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="Type" VerticalAlignment="Center" />
                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding CameraTypes}" SelectedItem="{Binding NewType}" />
                                </Grid>

                                <!-- USB: pick a detected device -->
                                <Grid ColumnDefinitions="120,*,Auto" IsVisible="{Binding IsUsbType}">
                                    <TextBlock Grid.Column="0" Text="USB device" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding DetectedUsbDevices}" SelectedItem="{Binding NewUsbDevice}" />
                                        <TextBlock Text="Plugged-in USB cameras are listed here — click ⟳ if you just connected one."
                                                   Foreground="#6B7280" FontSize="11" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Margin="6,0,0,0" VerticalAlignment="Top" Content="⟳"
                                            Command="{Binding RefreshUsbDevicesCommand}" ToolTip.Tip="Rescan USB" />
                                </Grid>

                                <!-- Network: URL -->
                                <Grid ColumnDefinitions="120,*" IsVisible="{Binding IsNetworkType}">
                                    <TextBlock Grid.Column="0" Text="URL" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding NewUrl}" Watermark="rtsp://… or http://…/video" />
                                </Grid>

                                <Grid ColumnDefinitions="120,*,120,*">
                                    <TextBlock Grid.Column="0" Text="Name *" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Margin="0,0,8,0" Text="{Binding NewName}" Watermark="required" />
                                    <TextBlock Grid.Column="2" Text="Suffix *" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="3" Text="{Binding NewSuffix}" Watermark="required" />
                                </Grid>

                                <Button Content="Add camera" Command="{Binding AddCameraCommand}" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <!-- header row -->
                        <Grid ColumnDefinitions="90,40,*,110,140,58,36" Margin="4,6,4,0">
                            <TextBlock Grid.Column="0" Text="Status" FontSize="12" Foreground="#6B7280" />
                            <TextBlock Grid.Column="1" Text="On" FontSize="12" Foreground="#6B7280" />
                            <TextBlock Grid.Column="2" Text="Name" FontSize="12" Foreground="#6B7280" />
                            <TextBlock Grid.Column="3" Text="Suffix" FontSize="12" Foreground="#6B7280" />
                            <TextBlock Grid.Column="4" Text="Source" FontSize="12" Foreground="#6B7280" />
                        </Grid>
                    </StackPanel>

                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Margin="0,6,0,0">
                        <ItemsControl ItemsSource="{Binding Cameras}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CameraSettingRowViewModel">
                                    <Grid ColumnDefinitions="90,40,*,110,140,58,36" Margin="4,6">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <Ellipse Width="9" Height="9" Fill="{Binding StatusBrush}" />
                                            <TextBlock Text="{Binding StatusText}" FontSize="12" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="2" Margin="0,0,6,0" Text="{Binding DisplayName}" />
                                        <TextBox Grid.Column="3" Margin="0,0,6,0" Text="{Binding Suffix}" />
                                        <TextBlock Grid.Column="4" Text="{Binding SourceLabel}" VerticalAlignment="Center"
                                                   Foreground="#6B7280" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="5" Content="Test" Margin="0,0,6,0"
                                                Command="{Binding $parent[ItemsControl].((vm:CameraSettingsViewModel)DataContext).TestCameraCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Grid.Column="6" Content="✕"
                                                Command="{Binding $parent[ItemsControl].((vm:CameraSettingsViewModel)DataContext).RemoveCameraCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- Timing -->
            <TabItem Header="Timing">
                <StackPanel Spacing="12" Margin="4,12" MaxWidth="520" HorizontalAlignment="Left">
                    <TextBlock Text="Timing device" FontWeight="SemiBold" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding TimingSources}"
                              SelectedItem="{Binding TimingSource}" />
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12"
                               Text="Manual = on-screen trigger buttons only. ALGE TimY3 reads timing events from the device's serial / USB-serial port." />

                    <Grid ColumnDefinitions="100,*,Auto" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Serial port" VerticalAlignment="Center" Margin="0,4" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,4,6,4" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding SerialPorts}"
                                  SelectedItem="{Binding TimingSerialPort}" />
                        <Button Grid.Row="0" Grid.Column="2" Margin="0,4" Content="⟳"
                                Command="{Binding RefreshSerialPortsCommand}" ToolTip.Tip="Refresh ports" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Baud rate" VerticalAlignment="Center" Margin="0,4" />
                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,4" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding BaudRates}"
                                  SelectedItem="{Binding TimingBaudRate}" />
                    </Grid>

                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12"
                               Text="Connect/disconnect the device from the Recording screen. USB-only TimY3 units that don't expose a COM port need ALGE's USB SDK via an external bridge (see project docs)." />
                </StackPanel>
            </TabItem>

            <!-- Filename format -->
            <TabItem Header="Filename">
                <StackPanel Spacing="12" Margin="4,12" MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock Text="Filename format" FontWeight="SemiBold" />
                    <TextBox Text="{Binding FilenameFormat}" />
                    <TextBlock TextWrapping="Wrap" Foreground="#6B7280" FontSize="12"
                               Text="Tokens: {date} {category} {discipline} {serie} {camera}. Empty values collapse and the camera suffix is appended automatically per camera." />
                    <Border Background="#F3F4F6" CornerRadius="6" Padding="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Preview" FontSize="12" Foreground="#6B7280" />
                            <TextBlock Text="{Binding FilenamePreview}" FontFamily="Consolas" FontSize="14" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>

</UserControl>
