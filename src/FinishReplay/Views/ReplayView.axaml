<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FinishReplay.ViewModels"
             xmlns:conv="using:FinishReplay.Converters"
             xmlns:session="using:FinishReplay.Services.Session"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="660"
             x:Class="FinishReplay.Views.ReplayView"
             x:DataType="vm:ReplayViewModel">

    <UserControl.Resources>
        <conv:FractionWidthConverter x:Key="FractionWidth" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="280,*" Margin="16">

        <!-- Left: sessions, cameras, markers -->
        <Grid Grid.Column="0" RowDefinitions="*,Auto,*" Margin="0,0,16,0">

            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Top" Text="Sessions" FontWeight="SemiBold" Margin="0,0,0,6" />
                <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                    <ListBox ItemsSource="{Binding RecentSessions}" SelectedItem="{Binding SelectedSession}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="session:SessionInfo">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding SessionId}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding RecordedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                               Foreground="#6B7280" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <StackPanel Grid.Row="1" Spacing="6" Margin="0,12">
                <TextBlock Text="Cameras (select to view)" FontWeight="SemiBold" />
                <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                    <ItemsControl ItemsSource="{Binding Cameras}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReplayCameraViewModel">
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="8,4">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" Margin="0,0,6,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" />
                                        <TextBlock Text="{Binding SourceType}" Foreground="#6B7280" FontSize="11" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#2563EB"
                                               FontSize="12" Text="{Binding SyncOffsetMs, StringFormat='+{0:0.#} ms'}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <DockPanel Grid.Row="2">
                <TextBlock DockPanel.Dock="Top" Text="Markers" FontWeight="SemiBold" Margin="0,0,0,6" />
                <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                    <ListBox ItemsSource="{Binding Markers}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReplayMarkerViewModel">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Content="Jump"
                                            Command="{Binding $parent[ItemsControl].((vm:ReplayViewModel)DataContext).JumpToMarkerCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>
        </Grid>

        <!-- Right: camera tiles + timeline + transport -->
        <DockPanel Grid.Column="1">

            <!-- Transport + timeline -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Spacing="10">

                <!-- Timeline: progress fill, marker ticks, position indicator. Click/drag to seek. -->
                <Grid x:Name="Timeline" Height="44" Background="Transparent" Cursor="Hand"
                      PointerPressed="OnTimelinePressed" PointerMoved="OnTimelineMoved">
                    <Border Background="#E5E7EB" CornerRadius="4" />

                    <Rectangle HorizontalAlignment="Left" Fill="#BFDBFE" RadiusX="4" RadiusY="4">
                        <Rectangle.Width>
                            <MultiBinding Converter="{StaticResource FractionWidth}">
                                <Binding Path="PositionFraction" />
                                <Binding Path="Bounds.Width" ElementName="Timeline" />
                            </MultiBinding>
                        </Rectangle.Width>
                    </Rectangle>

                    <!-- Reflection bindings here: the ContentPresenter style binds per-item Fraction. -->
                    <ItemsControl ItemsSource="{Binding Markers}" x:CompileBindings="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                            <Style Selector="ContentPresenter">
                                <Setter Property="Canvas.Left">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource FractionWidth}">
                                            <Binding Path="Fraction" />
                                            <Binding Path="Bounds.Width" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="4" Height="44" Padding="0" Background="#DC2626"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip.Tip="{Binding Label}"
                                        Command="{Binding DataContext.JumpToMarkerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Canvas>
                        <Rectangle Width="2" Height="44" Fill="#111827">
                            <Canvas.Left>
                                <MultiBinding Converter="{StaticResource FractionWidth}">
                                    <Binding Path="PositionFraction" />
                                    <Binding Path="Bounds.Width" ElementName="Timeline" />
                                </MultiBinding>
                            </Canvas.Left>
                        </Rectangle>
                    </Canvas>
                </Grid>

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding PositionText}" FontFamily="Consolas" />
                    <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontFamily="Consolas" Foreground="#6B7280" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Content="⏮ Frame" Command="{Binding StepBackwardCommand}" />
                    <Button Content="Play / Pause" Command="{Binding PlayPauseCommand}" Padding="16,8" />
                    <Button Content="Frame ⏭" Command="{Binding StepForwardCommand}" />
                    <CheckBox Content="Timestamp" IsChecked="{Binding ShowWatermark}" VerticalAlignment="Center"
                              Margin="12,0,0,0" ToolTip.Tip="Overlay the recording date and time on the video" />
                </StackPanel>
            </StackPanel>

            <!-- Selected camera tiles fill the space in a grid (synchronized) -->
            <Border Background="#0B1220" CornerRadius="6" Padding="6">
                <Grid>
                    <ItemsControl ItemsSource="{Binding VisibleCameras}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReplayCameraViewModel">
                                <Border Margin="4" CornerRadius="6" ClipToBounds="True"
                                        Background="#111827" BorderBrush="#1F2937" BorderThickness="1">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Bottom" Background="#0B1220" Padding="8,4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#E5E7EB" />
                                                <TextBlock Grid.Column="1" Text="{Binding CameraTimeText}"
                                                           Foreground="#60A5FA" FontFamily="Consolas" />
                                            </Grid>
                                        </Border>
                                        <Grid>
                                            <Image Source="{Binding CurrentFrame}" Stretch="Uniform" />
                                            <TextBlock Text="no frames" Foreground="#374151" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding CurrentFrame, Converter={x:Static ObjectConverters.IsNull}}" />

                                            <!-- Date+time watermark (togglable; on by default) -->
                                            <Border x:CompileBindings="False" VerticalAlignment="Top" HorizontalAlignment="Left"
                                                    Margin="8" Padding="6,2" CornerRadius="3" Background="#99000000"
                                                    IsVisible="{Binding $parent[ItemsControl].DataContext.ShowWatermark}">
                                                <TextBlock Text="{Binding $parent[ItemsControl].DataContext.WatermarkText}"
                                                           Foreground="#F9FAFB" FontFamily="Consolas" FontSize="13" />
                                            </Border>
                                        </Grid>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Select a session, then choose cameras to view."
                               Foreground="#9CA3AF" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding !HasSession}" />
                </Grid>
            </Border>
        </DockPanel>
    </Grid>

</UserControl>
